# ============================================================
# PM AI Agent 配置文件
# 复制此文件为 .env 并填入实际的配置值
# ============================================================

# --- 应用配置 ---
APP_NAME=PM_AI_Agent
DEBUG=False
HOST=0.0.0.0
PORT=9900

# CORS 允许的源（生产环境请设为具体域名，逗号分隔）
CORS_ORIGINS=http://localhost:9900,http://127.0.0.1:9900

# --- LLM 配置（OpenAI 兼容模式）---
# 支持 DeepSeek / MiniMax / DashScope 等所有 OpenAI 兼容 API
DASHSCOPE_API_KEY=your-api-key-here
DASHSCOPE_API_BASE=https://api.deepseek.com
DASHSCOPE_MODEL=deepseek-chat
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# --- SiliconFlow Embedding 配置（可选）---
# 用于独立的向量嵌入服务，不填则回退到 DASHSCOPE_API_KEY
SILICONFLOW_API_KEY=your-siliconflow-key-here
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# --- Milvus 向量数据库 ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000

# --- RAG 配置 ---
RAG_TOP_K=3

# --- 文档分块配置 ---
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# --- MCP 服务配置 ---
# Project MCP Server（项目管理工具，端口 8003）
MCP_PROJECT_TRANSPORT=streamable-http
MCP_PROJECT_URL=http://localhost:8003/mcp

# Knowledge MCP Server（知识库工具，端口 8004）
MCP_KNOWLEDGE_TRANSPORT=streamable-http
MCP_KNOWLEDGE_URL=http://localhost:8004/mcp
